# ─────────────────────────────────────────────────────────────────────────────
# Imera Elektro — Ortam Değişkenleri (Hostinger / production)
# Bu dosyayı ".env" olarak kopyalayıp değerleri doldurun. .env git'e GİRMEZ.
# Turso ve Stripe değerlerini mevcut Vercel projesinden (Settings → Environment
# Variables) kopyalayın — bunlar şu an sadece Vercel'de tanımlı.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
# PORT: Hostinger/Passenger otomatik atar; boş bırakılabilir. Lokal için 3000.
PORT=3000

# Oturum imzalama anahtarı — uzun, rastgele bir string koyun
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Veritabanı: Turso (production) — Vercel'den kopyalayın ───────────────────
# Bu ikisi tanımlıysa uygulama Turso kullanır; boşsa lokal SQLite dosyası.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Görsel yükleme: Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Ödeme: Stripe (LIVE anahtar — Vercel'den kopyalayın) ────────────────────
STRIPE_SECRET_KEY=

# ─── E-Posta (SMTP) — Hostinger mail ─────────────────────────────────────────
SMTP_HOST=mail.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@imeragroup.com
SMTP_PASS=

# ─── Admin & çeşitli ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@imeraelektro.at
ADMIN_PASSWORD=
BANK_IBAN=
# Sipariş mailindeki admin linki için canlı adres
SITE_URL=https://www.imeragroup.com
