<%- include('../partials/header') %>

<main>
  <div class="container">
    <div class="account-layout">
      <aside class="account-sidebar">
        <h3>Mein Konto</h3>
        <nav>
          <a href="/konto" class="active">Übersicht</a>
          <a href="/konto/bestellungen">Meine Bestellungen</a>
        </nav>
        <form action="/konto/abmelden" method="POST" style="margin-top:1rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-outline btn-sm">Abmelden</button>
        </form>
      </aside>

      <div class="account-content">
        <h1>Guten Tag, <%= user.name || user.email %>!</h1>

        <div class="account-stats">
          <div class="account-stat"><div class="stat-num"><%= orders.length %></div><div class="stat-label">Bestellungen</div></div>
        </div>

        <style>
          .gutschein { display:flex; align-items:center; justify-content:space-between; gap:1rem; border:1.5px dashed #34C759; border-radius:12px; padding:14px 18px; margin-bottom:12px; background:#F0FDF4; }
          .gutschein--used { border-style:solid; border-color:#E5E7EB; background:#F9FAFB; opacity:.7; }
          .gutschein-value { font-size:18px; font-weight:700; color:#166534; }
          .gutschein--used .gutschein-value { color:#6B7280; }
          .gutschein-code { margin-top:5px; }
          .gutschein-code span { font-family:"SF Mono","Fira Code","Consolas",monospace; font-size:15px; font-weight:600; letter-spacing:.5px; background:#fff; border:1px solid #D1FAE5; border-radius:6px; padding:3px 10px; display:inline-block; color:#1D1D1F; }
          .gutschein-meta { font-size:12px; color:#6B7280; margin-top:6px; }
          .gutschein-copy { background:#34C759; color:#fff; border:none; border-radius:980px; padding:9px 18px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; }
          .gutschein-copy:hover { background:#16a34a; }
          .gutschein-badge { font-size:12px; font-weight:600; color:#6B7280; background:#fff; border:1px solid #E5E7EB; border-radius:980px; padding:4px 12px; white-space:nowrap; }
          @media (max-width:480px){ .gutschein{flex-direction:column;align-items:stretch;text-align:center;} .gutschein-copy{width:100%;} }
        </style>
        <div class="section-card">
          <h2>🎟 Meine Gutscheine</h2>
          <%
            const _now = new Date();
            const _isActive = (c) => c.active && c.used_count < c.max_uses && (!c.expires_at || new Date(c.expires_at) >= _now);
            const _coupons = locals.coupons || [];
            const _active = _coupons.filter(_isActive);
            const _inactive = _coupons.filter(c => !_isActive(c));
          %>
          <% if (!_coupons.length) { %>
            <p class="text-gray">Sie haben aktuell keine Gutscheine. Bei Ihrer Registrierung erhalten Neukunden automatisch einen Willkommensrabatt.</p>
          <% } else { %>
            <% for (const c of _active) { %>
            <div class="gutschein gutschein--active">
              <div class="gutschein-left">
                <div class="gutschein-value"><%= c.type === 'percent' ? c.value + '% Rabatt' : formatEuro(c.value) + ' Rabatt' %></div>
                <div class="gutschein-code"><span><%= c.code %></span></div>
                <div class="gutschein-meta">
                  <% if (c.min_order > 0) { %>Ab <%= formatEuro(c.min_order) %> Bestellwert · <% } %>
                  <% if (c.expires_at) { %>Gültig bis <%= formatDate(c.expires_at) %><% } else { %>Unbegrenzt gültig<% } %>
                </div>
              </div>
              <button type="button" class="gutschein-copy" data-code="<%= c.code %>">Code kopieren</button>
            </div>
            <% } %>
            <% if (!_active.length) { %><p class="text-gray">Aktuell keine aktiven Gutscheine.</p><% } %>
            <% for (const c of _inactive) { %>
            <div class="gutschein gutschein--used">
              <div class="gutschein-left">
                <div class="gutschein-value"><%= c.type === 'percent' ? c.value + '%' : formatEuro(c.value) %></div>
                <div class="gutschein-code"><span><%= c.code %></span></div>
              </div>
              <span class="gutschein-badge"><%= (c.used_count >= c.max_uses) ? '✓ Eingelöst' : 'Abgelaufen' %></span>
            </div>
            <% } %>
          <% } %>
        </div>

        <div class="section-card">
          <h2>Letzte Bestellungen</h2>
          <% if (orders.length === 0) { %>
          <p class="text-gray">Sie haben noch keine Bestellungen aufgegeben.</p>
          <a href="/shop" class="btn-blue">Jetzt einkaufen</a>
          <% } else { %>
          <div class="table-scroll">
          <table class="data-table">
            <thead><tr><th>Bestellnummer</th><th>Datum</th><th>Gesamt (inkl. MwSt.)</th><th>Status</th><th></th></tr></thead>
            <tbody>
              <% for (const o of orders) { %>
              <tr>
                <td><%= o.order_number %></td>
                <td><%= formatDate(o.created_at) %></td>
                <td><%= formatEuro(grossAmount(o.total)) %></td>
                <td><span class="status-badge status-<%= orderStatusClass(o.status) %>"><%= orderStatusLabel(o.status) %></span></td>
                <td><a href="/konto/bestellungen/<%= o.order_number %>" class="btn-sm btn-outline">Details</a></td>
              </tr>
              <% } %>
            </tbody>
          </table>
          </div>
          <% } %>
        </div>

        <div class="section-card">
          <h2>Profil bearbeiten</h2>
          <form action="/konto/profil" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-grid">
              <div class="form-group"><label>Vorname</label><input type="text" name="vorname" value="<%= user.first_name || '' %>"></div>
              <div class="form-group"><label>Nachname</label><input type="text" name="nachname" value="<%= user.last_name || '' %>"></div>
              <div class="form-group"><label>Unternehmen</label><input type="text" name="company" value="<%= user.company || '' %>"></div>
              <div class="form-group"><label>Telefon</label><input type="tel" name="phone" value="<%= user.phone || '' %>"></div>
            </div>
            <div class="form-group"><label>Lieferadresse</label><textarea name="address" rows="3"><%= user.address || '' %></textarea></div>
            <button type="submit" class="btn-blue">Speichern</button>
          </form>
        </div>

        <div class="section-card danger-zone">
          <h2>Konto löschen</h2>
          <p>Löschen Sie Ihr Konto und alle damit verbundenen persönlichen Daten dauerhaft. Diese Aktion kann nicht rückgängig gemacht werden.</p>
          <a href="/konto/konto-loeschen" class="btn-danger">Konto löschen</a>
        </div>

        <div class="section-card">
          <h2>Passwort ändern</h2>
          <form action="/konto/passwort" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-grid">
              <div class="form-group"><label>Aktuelles Passwort</label><input type="password" name="current" required></div>
              <div class="form-group"><label>Neues Passwort</label><input type="password" name="password" required minlength="8"></div>
              <div class="form-group"><label>Wiederholen</label><input type="password" name="password2" required></div>
            </div>
            <button type="submit" class="btn-blue">Passwort ändern</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
document.querySelectorAll('.gutschein-copy').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var code = btn.getAttribute('data-code');
    function done() { var o = btn.textContent; btn.textContent = '✓ Kopiert'; setTimeout(function(){ btn.textContent = o; }, 1500); }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(done).catch(done);
    } else {
      var t = document.createElement('textarea'); t.value = code; document.body.appendChild(t); t.select();
      try { document.execCommand('copy'); } catch(e) {}
      document.body.removeChild(t); done();
    }
  });
});
</script>

<%- include('../partials/footer') %>
