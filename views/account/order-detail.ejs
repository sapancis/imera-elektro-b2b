<%- include('../partials/header') %>
<main><div class="container">
  <div class="account-layout">
    <aside class="account-sidebar">
      <h3>Mein Konto</h3>
      <nav><a href="/konto">Übersicht</a><a href="/konto/bestellungen" class="active">Meine Bestellungen</a></nav>
    </aside>
    <div class="account-content">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:1rem">
        <a href="/konto/bestellungen" class="back-link">← Zurück zu Bestellungen</a>
        <form action="/konto/bestellungen/<%= order.order_number %>/erneut" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-sm btn-green">🔄 Erneut bestellen</button>
        </form>
      </div>
      <h1><%= order.order_number %></h1>
      <div class="order-meta">
        <span>Datum: <%= formatDate(order.created_at) %></span>
        <span class="status-badge status-<%= orderStatusClass(order.status) %>"><%= orderStatusLabel(order.status) %></span>
        <span>Zahlung: <%= order.payment_method === 'transfer' ? 'Überweisung' : 'Rechnung' %></span>
        <a href="/konto/bestellungen/<%= order.order_number %>/rechnung.pdf" class="btn-sm btn-outline" style="margin-left:auto">📥 PDF Rechnung</a>
      </div>
      <div class="table-scroll">
        <table class="data-table">
          <thead><tr><th>Produkt</th><th>Menge</th><th>Preis/Stk</th><th>Gesamt</th></tr></thead>
          <tbody>
            <% for (const item of items) { %>
            <tr>
              <td><%= item.product_name %><% if (item.product_sku) { %><br><small>Art.-Nr.: <%= item.product_sku %></small><% } %></td>
              <td><%= item.quantity %></td>
              <td><%= formatPrice(item.unit_price) %></td>
              <td><%= formatEuro(item.total_price) %></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div class="order-totals">
        <div class="summary-row"><span>Zwischensumme</span><span><%= formatEuro(order.subtotal) %></span></div>
        <div class="summary-row"><span>Versand</span><span><%= order.shipping > 0 ? formatEuro(order.shipping) : 'Kostenlos' %></span></div>
        <div class="summary-total"><span>Gesamt</span><span><%= formatEuro(order.total) %></span></div>
      </div>
      <% if (order.shipping_address) { %>
      <div class="section-card"><h3>Lieferadresse</h3><pre style="font-family:inherit;margin:0;white-space:pre-wrap"><%= order.shipping_address %></pre></div>
      <% } %>
    </div>
  </div>
</div></main>
<%- include('../partials/footer') %>
