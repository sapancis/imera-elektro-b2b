<%- include('../partials/header') %>
<main><div class="container">
  <div class="account-layout">
    <aside class="account-sidebar">
      <h3>Mein Konto</h3>
      <nav><a href="/konto">Übersicht</a><a href="/konto/bestellungen" class="active">Meine Bestellungen</a></nav>
    </aside>
    <div class="account-content">
      <h1>Meine Bestellungen</h1>
      <% if (orders.length === 0) { %>
      <div class="empty-state"><div class="empty-icon">📦</div><h2>Keine Bestellungen</h2><a href="/shop" class="btn-blue">Jetzt einkaufen</a></div>
      <% } else { %>
      <% for (const o of orders) { %>
      <div class="order-card">
        <div class="order-card-header">
          <div><strong><%= o.order_number %></strong> &nbsp;·&nbsp; <%= formatDate(o.created_at) %></div>
          <span class="status-badge status-<%= orderStatusClass(o.status) %>"><%= orderStatusLabel(o.status) %></span>
        </div>
        <div class="order-items-preview">
          <% for (const item of o.items) { %>
          <div class="order-item-row"><span><%= item.product_name %> × <%= item.quantity %></span><span><%= formatEuro(item.total_price) %></span></div>
          <% } %>
        </div>
        <div class="order-card-footer">
          <strong>Gesamt: <%= formatEuro(grossAmount(o.total)) %></strong> <span style="font-weight:400;color:#9CA3AF;font-size:12px">inkl. MwSt.</span>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
            <a href="/konto/bestellungen/<%= o.order_number %>" class="btn-sm btn-outline">Details anzeigen</a>
            <form action="/konto/bestellungen/<%= o.order_number %>/erneut" method="POST" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-sm btn-green">🔄 Erneut bestellen</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>
  </div>
</div></main>
<%- include('../partials/footer') %>
