<!DOCTYPE html>
<html lang="de"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Kategorien – Admin</title><link rel="stylesheet" href="/css/admin.css?v=6"></head>
<body class="admin-body">
<% if (locals.flash) { %><div class="admin-flash admin-flash-<%= flash.type %>"><span><%= flash.message %></span><button onclick="this.parentElement.remove()">×</button></div><% } %>
<%- include('../partials/admin-nav') %>
<div class="admin-main">
  <div class="admin-topbar"><div class="admin-page-title">Kategorien</div></div>
  <div class="admin-content">
    <div class="admin-form-grid">
      <div class="admin-card">
        <h3>Neue Kategorie</h3>
        <form action="/admin/kategorien/neu" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group"><label>Name *</label><input type="text" name="name" required></div>
          <div class="form-group"><label>Icon (Emoji)</label><input type="text" name="icon" value="📦" maxlength="4"></div>
          <div class="form-group"><label>Beschreibung</label><input type="text" name="description"></div>
          <div class="form-group"><label>Reihenfolge</label><input type="number" name="sort_order" value="0"></div>
          <button type="submit" class="btn-blue">Erstellen</button>
        </form>
      </div>
      <div class="admin-card">
        <h3>Vorhandene Kategorien</h3>
        <% for (const cat of categories) { %>
        <details class="cat-details">
          <summary><%= cat.icon %> <%= cat.name %> <small>(<%= cat.product_count %> Produkte)</small></summary>
          <form action="/admin/kategorien/<%= cat.id %>/bearbeiten" method="POST" style="padding:1rem 0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-grid-2">
              <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= cat.name %>"></div>
              <div class="form-group"><label>Slug</label><input type="text" name="slug" value="<%= cat.slug %>"></div>
              <div class="form-group"><label>Icon</label><input type="text" name="icon" value="<%= cat.icon %>"></div>
              <div class="form-group"><label>Reihenfolge</label><input type="number" name="sort_order" value="<%= cat.sort_order %>"></div>
            </div>
            <div class="form-group"><label>Beschreibung</label><input type="text" name="description" value="<%= cat.description || '' %>"></div>
            <label class="checkbox-label"><input type="checkbox" name="active" value="1" <%= cat.active ? 'checked' : '' %>> Aktiv</label>
            <button type="submit" class="btn-blue btn-sm" style="margin-top:0.5rem">Speichern</button>
          </form>
        </details>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin.js"></script>
</body></html>
