<!DOCTYPE html>
<html lang="de"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Produkte – Admin</title><link rel="stylesheet" href="/css/admin.css"></head>
<body class="admin-body">
<% if (locals.flash) { %><div class="admin-flash admin-flash-<%= flash.type %>"><span><%= flash.message %></span><button onclick="this.parentElement.remove()">×</button></div><% } %>
<%- include('../partials/admin-nav') %>
<div class="admin-main">
  <div class="admin-topbar">
    <div class="admin-page-title">Produkte</div>
    <a href="/admin/produkte/neu" class="btn-blue">+ Neues Produkt</a>
  </div>
  <div class="admin-content">
    <form class="admin-filters" action="/admin/produkte" method="GET">
      <input type="text" name="q" value="<%= q || '' %>" placeholder="Suche nach Name oder Art.-Nr." class="admin-search">
      <select name="kat" onchange="this.form.submit()">
        <option value="">Alle Kategorien</option>
        <% for (const cat of categories) { %><option value="<%= cat.slug %>" <%= kat===cat.slug ? 'selected' : '' %>><%= cat.name %></option><% } %>
      </select>
      <button type="submit" class="btn-blue btn-sm">Suchen</button>
    </form>

    <div class="admin-card">
      <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Bild</th><th>Name / Art.-Nr.</th><th>Kategorie</th><th>Preis ab</th><th>Lager</th><th>Status</th><th>Aktionen</th></tr></thead>
        <tbody>
          <% for (const p of products) { %>
          <tr class="<%= !p.active ? 'row-inactive' : '' %>">
            <td><div class="product-thumb"><%= p.image ? `<img src="${p.image}" style="width:40px;height:40px;object-fit:cover;border-radius:4px">` : '📦' %></div></td>
            <td>
              <div class="product-name-cell"><a href="/admin/produkte/<%= p.id %>/bearbeiten"><strong><%= p.name %></strong></a></div>
              <small class="text-gray"><%= p.sku || '–' %></small>
            </td>
            <td><%= p.cat_name || '–' %></td>
            <td class="text-green"><%= p.price_min ? formatPrice(p.price_min) : '–' %></td>
            <td class="<%= p.stock === 0 ? 'text-red' : '' %>"><%= p.stock %></td>
            <td>
              <% if (p.featured) { %><span class="badge-small badge-green">Featured</span><% } %>
              <span class="badge-small <%= p.active ? 'badge-green' : 'badge-gray' %>"><%= p.active ? 'Aktiv' : 'Inaktiv' %></span>
            </td>
            <td>
              <a href="/admin/produkte/<%= p.id %>/bearbeiten" class="btn-sm btn-outline">Bearbeiten</a>
              <form action="/admin/produkte/<%= p.id %>/loeschen" method="POST" style="display:inline" onsubmit="return confirm('Produkt deaktivieren?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn-sm btn-danger">Deaktivieren</button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin.js"></script>
</body></html>
