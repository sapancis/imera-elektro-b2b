<!DOCTYPE html>
<html lang="de"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Einstellungen – Admin</title><link rel="stylesheet" href="/css/admin.css?v=7"></head>
<body class="admin-body">
<% if (locals.flash) { %><div class="admin-flash admin-flash-<%= flash.type %>"><span><%= flash.message %></span><button onclick="this.parentElement.remove()">×</button></div><% } %>
<%- include('../partials/admin-nav') %>
<div class="admin-main">
  <div class="admin-topbar"><div class="admin-page-title">Einstellungen</div></div>
  <div class="admin-content">
    <form action="/admin/einstellungen" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="admin-form-grid">
        <div class="admin-card">
          <h3>Website-Informationen</h3>
          <div class="form-group"><label>Website-Name</label><input type="text" name="site_name" value="<%= settings.site_name || '' %>"></div>
          <div class="form-group"><label>Tagline</label><input type="text" name="site_tagline" value="<%= settings.site_tagline || '' %>"></div>
          <div class="form-group"><label>Meta-Beschreibung (SEO)</label><textarea name="meta_description" rows="3"><%= settings.meta_description || '' %></textarea></div>
        </div>
        <div class="admin-card">
          <h3>Kontaktdaten</h3>
          <div class="form-group"><label>Telefon</label><input type="text" name="contact_phone" value="<%= settings.contact_phone || '' %>"></div>
          <div class="form-group"><label>E-Mail</label><input type="email" name="contact_email" value="<%= settings.contact_email || '' %>"></div>
          <div class="form-group"><label>Website</label><input type="text" name="contact_website" value="<%= settings.contact_website || '' %>"></div>
        </div>
        <div class="admin-card">
          <h3>Shop-Einstellungen</h3>
          <div class="form-group"><label>Lieferzeit-Angabe</label><input type="text" name="shipping_info" value="<%= settings.shipping_info || '2-5 Werktage' %>"></div>
          <div class="form-group"><label>Kostenloser Versand ab (€)</label><input type="number" name="free_shipping_threshold" value="<%= settings.free_shipping_threshold || '200' %>"></div>
          <div class="form-group"><label>Rechtlicher Hinweis (Footer)</label><input type="text" name="company_legal" value="<%= settings.company_legal || '' %>"></div>
          <div class="form-group"><label>Willkommensrabatt für Neukunden (%)</label><input type="number" name="welcome_discount_percent" value="<%= settings.welcome_discount_percent || '10' %>" min="0" max="100"><small style="color:#6B7280">0 = deaktiviert. Wird als Gutschein bei Registrierung vergeben.</small></div>
        </div>
        <div class="admin-card">
          <h3>Zahlungs-Integrationen</h3>
          <div class="form-group"><label>Stripe Publishable Key</label><input type="text" name="stripe_publishable_key" value="<%= settings.stripe_publishable_key || '' %>" placeholder="pk_live_..."><small style="color:#6B7280">Den Secret Key als Umgebungsvariable STRIPE_SECRET_KEY setzen.</small></div>
        </div>
        <div class="admin-card">
          <h3>Live-Chat (Tawk.to)</h3>
          <div class="form-group"><label>Tawk.to Property ID / Widget ID</label><input type="text" name="tawkto_property_id" value="<%= settings.tawkto_property_id || '' %>" placeholder="z.B. 5f1234abc5e1234/default"><small style="color:#6B7280">Format: PROPERTYID/WIDGETID (z.B. 64abc123def456789/1hab2cde3). Finden Sie die ID unter tawk.to → Administration → Chat Widget. Leer lassen = deaktiviert.</small></div>
        </div>
        <div class="admin-card">
          <h3>Google Analytics</h3>
          <div class="form-group"><label>Google Analytics Measurement ID</label><input type="text" name="google_analytics_id" value="<%= settings.google_analytics_id || '' %>" placeholder="G-XXXXXXXXXX"><small style="color:#6B7280">Format: G-XXXXXXXXXX (Google Analytics 4). Leer lassen = deaktiviert. Wird automatisch im Header eingebunden.</small></div>
        </div>
        <div class="admin-card">
          <h3>Soziale Medien</h3>
          <p style="font-size:13px;color:#6B7280;margin-bottom:1rem">Vollständige URL eingeben (z.B. https://www.instagram.com/imeraelektro). Leer lassen = Icon wird ausgeblendet.</p>
          <div class="form-group">
            <label>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
              Instagram URL
            </label>
            <input type="url" name="social_instagram" value="<%= settings.social_instagram || '' %>" placeholder="https://www.instagram.com/imeraelektro">
          </div>
          <div class="form-group">
            <label>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.77a8.18 8.18 0 004.78 1.52V6.85a4.85 4.85 0 01-1.01-.16z"/></svg>
              TikTok URL
            </label>
            <input type="url" name="social_tiktok" value="<%= settings.social_tiktok || '' %>" placeholder="https://www.tiktok.com/@imeraelektro">
          </div>
          <div class="form-group">
            <label>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn URL
            </label>
            <input type="url" name="social_linkedin" value="<%= settings.social_linkedin || '' %>" placeholder="https://www.linkedin.com/company/imeraelektro">
          </div>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-blue btn-lg">Einstellungen speichern</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/admin.js"></script>
</body></html>
