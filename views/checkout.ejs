<%- include('partials/header') %>

<main>
  <div class="container">
    <h1 class="page-title">Kasse</h1>
    <div class="checkout-layout">
      <form action="/kasse/bestellung" method="POST" class="checkout-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-section">
          <h2>Kontaktdaten</h2>
          <div class="form-grid">
            <div class="form-group">
              <label>Vorname *</label>
              <input type="text" name="vorname" value="<%= user?.first_name || '' %>" required placeholder="Vorname">
            </div>
            <div class="form-group">
              <label>Nachname *</label>
              <input type="text" name="nachname" value="<%= user?.last_name || '' %>" required placeholder="Nachname">
            </div>
            <div class="form-group">
              <label>E-Mail *</label>
              <input type="email" name="email" value="<%= user?.email || '' %>" required placeholder="ihre@email.at">
            </div>
            <div class="form-group">
              <label>Unternehmen</label>
              <input type="text" name="company" value="<%= user?.company || '' %>" placeholder="Firma GmbH">
            </div>
            <div class="form-group">
              <label>Telefon</label>
              <input type="tel" name="phone" value="<%= user?.phone || '' %>" placeholder="+43 ...">
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2>Lieferadresse *</h2>
          <div class="form-group">
            <textarea name="address" required rows="3" placeholder="Straße, Hausnummer&#10;PLZ Ort&#10;Land"><%= user?.address || '' %></textarea>
          </div>
        </div>

        <div class="form-section">
          <h2>Zahlungsmethode</h2>
          <div class="payment-options">
            <label class="payment-option selected" id="pay-transfer">
              <input type="radio" name="payment_method" value="transfer" checked>
              <div>
                <strong>💳 Überweisung</strong>
                <p>IBAN wird nach Bestellbestätigung mitgeteilt</p>
              </div>
            </label>
            <% if (isStammkunde) { %>
            <label class="payment-option" id="pay-invoice">
              <input type="radio" name="payment_method" value="invoice">
              <div>
                <strong>📄 Auf Rechnung</strong>
                <p>Zahlungsziel 14 Tage – freigeschaltet für Stammkunden</p>
              </div>
            </label>
            <% } else { %>
            <div class="payment-option payment-option--locked" title="Nur für freigeschaltete Stammkunden verfügbar">
              <div class="payment-locked-icon">🔒</div>
              <div>
                <strong style="color:#9CA3AF">📄 Auf Rechnung</strong>
                <p style="color:#9CA3AF">Nur für freigeschaltete Stammkunden. <a href="/kontakt" target="_blank" style="color:#3B82F6">Jetzt anfragen →</a></p>
              </div>
            </div>
            <% } %>
          </div>
        </div>

        <div class="form-section">
          <h2>Anmerkungen</h2>
          <div class="form-group">
            <textarea name="notes" rows="2" placeholder="Lieferhinweise, Bestellnummer Ihres Unternehmens, etc."></textarea>
          </div>
        </div>

        <div class="form-section form-agb">
          <label class="checkbox-label">
            <input type="checkbox" required>
            Ich habe die <a href="/agb" target="_blank">AGB</a> und die <a href="/datenschutz" target="_blank">Datenschutzerklärung</a> gelesen und akzeptiere diese.
          </label>
        </div>

        <input type="hidden" name="coupon_code" id="couponCodeInput">
        <button type="submit" class="btn-green btn-full btn-lg">Bestellung kostenpflichtig aufgeben →</button>
        <p style="font-size:12px;color:#6B7280;text-align:center;margin-top:8px">Alle Preise netto zzgl. 20% MwSt. (Regelbesteuerung)</p>
      </form>

      <% if (locals.stripeKey) { %>
      <div style="margin-top:12px">
        <button id="stripeBtn" class="btn-blue btn-full btn-lg">💳 Mit Kreditkarte bezahlen (Stripe)</button>
      </div>
      <% } %>

      <!-- Order Summary -->
      <div class="checkout-summary">
        <h3>Ihre Bestellung</h3>
        <% for (const item of items) { %>
        <div class="checkout-item">
          <div class="checkout-item-name"><%= item.product.name %></div>
          <div class="checkout-item-qty"><%= item.qty %> × <%= formatPrice(item.unitPrice) %></div>
          <div class="checkout-item-total"><%= formatEuro(item.lineTotal) %></div>
        </div>
        <% } %>
        <hr>
        <div class="summary-row"><span>Zwischensumme (netto)</span><span><%= formatEuro(subtotal) %></span></div>
        <div class="summary-row"><span>Versand</span><span><%= shipping > 0 ? formatEuro(shipping) : 'Kostenlos' %></span></div>
        <div class="summary-row" id="discountRow" style="display:none;color:#10B981"><span>Rabatt (<span id="discountLabel"></span>)</span><span id="discountAmt"></span></div>
        <div class="summary-row"><span>zzgl. <%= vatPercent %>% MwSt.</span><span id="taxDisplay"><%= formatEuro(tax) %></span></div>
        <div class="summary-total"><span>Gesamt (inkl. MwSt.)</span><span id="totalDisplay"><%= formatEuro(gross) %></span></div>

        <!-- Gutschein -->
        <div class="coupon-box">
          <div class="coupon-row">
            <input type="text" id="couponInput" placeholder="Gutscheincode" class="coupon-input">
            <button type="button" id="couponApply" class="btn-outline btn-sm">Einlösen</button>
          </div>
          <div id="couponMsg" style="font-size:13px;margin-top:6px"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
document.querySelectorAll('input[name="payment_method"]').forEach(r => {
  r.addEventListener('change', () => {
    document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
    r.parentElement.classList.add('selected');
  });
});

// Coupon
const csrf = '<%= csrfToken %>';
const subtotal = <%= subtotal %>;
let appliedDiscount = 0;

document.getElementById('couponApply')?.addEventListener('click', () => {
  const code = document.getElementById('couponInput').value.trim();
  if (!code) return;
  fetch('/kasse/coupon-pruefen', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `code=${encodeURIComponent(code)}&subtotal=${subtotal}&_csrf=${encodeURIComponent(csrf)}`
  }).then(r => r.json()).then(d => {
    const msg = document.getElementById('couponMsg');
    if (d.ok) {
      appliedDiscount = d.discount;
      document.getElementById('couponCodeInput').value = code;
      document.getElementById('discountRow').style.display = 'flex';
      document.getElementById('discountLabel').textContent = d.type === 'percent' ? d.value + '%' : d.value.toFixed(2) + '€';
      document.getElementById('discountAmt').textContent = '-' + d.discount.toFixed(2).replace('.', ',') + '€';
      const newNet = Math.max(0, subtotal + <%= shipping %> - d.discount);
      const newTax = Math.round(newNet * <%= VAT_RATE %> * 100) / 100;
      const newGross = Math.round((newNet + newTax) * 100) / 100;
      document.getElementById('taxDisplay').textContent = newTax.toFixed(2).replace('.', ',') + '€';
      document.getElementById('totalDisplay').textContent = newGross.toFixed(2).replace('.', ',') + '€';
      msg.style.color = '#10B981';
    } else {
      msg.style.color = '#EF4444';
    }
    msg.textContent = d.message;
  });
});

// Stripe
<% if (locals.stripeKey) { %>
document.getElementById('stripeBtn')?.addEventListener('click', () => {
  fetch('/kasse/stripe-session', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `_csrf=${encodeURIComponent(csrf)}`
  }).then(r => r.json()).then(d => {
    if (d.ok && d.url) window.location.href = d.url;
    else alert(d.message || 'Stripe-Fehler');
  });
});
<% } %>
</script>

<%- include('partials/footer') %>
