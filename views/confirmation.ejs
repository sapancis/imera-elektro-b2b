<%- include('partials/header') %>

<main>
  <div class="container">
    <div class="confirmation-box">
      <div class="confirmation-icon">✓</div>
      <h1>Bestellung erfolgreich!</h1>
      <p class="confirmation-number">Bestellnummer: <strong><%= order?.order_number %></strong></p>
      <p>Vielen Dank für Ihre Bestellung. Wir werden uns in Kürze mit Ihnen in Verbindung setzen.</p>

      <% if (order?.payment_method === 'transfer') { %>
      <div class="bank-info">
        <h3>💳 Zahlungsinformationen (Überweisung)</h3>
        <p>Bitte überweisen Sie den Betrag innerhalb von <strong>7 Tagen</strong> auf folgendes Konto:</p>
        <div class="bank-details">
          <div><strong>Empfänger:</strong> Imera Elektro</div>
          <div><strong>IBAN:</strong> <%= bankIban || 'Wird per E-Mail mitgeteilt' %></div>
          <div><strong>Betrag:</strong> <span style="color:#34C759;font-weight:700"><%= formatEuro(grossAmount(order.total)) %></span> <span style="color:#6E6E73;font-weight:400">(inkl. 20% MwSt.)</span></div>
          <div><strong>Verwendungszweck:</strong> <span style="font-family:monospace;background:#F5F5F7;padding:2px 8px;border-radius:4px"><%= order.order_number %></span></div>
        </div>
        <p style="font-size:13px;color:#6E6E73;margin-top:8px">⚠️ Bitte geben Sie unbedingt die Bestellnummer als Verwendungszweck an.</p>
      </div>
      <% } %>

      <div class="order-summary-confirm">
        <h3>Bestellübersicht</h3>
        <% for (const item of items) { %>
        <div class="confirm-item">
          <span><%= item.product_name %> × <%= item.quantity %></span>
          <span><%= formatEuro(item.total_price) %></span>
        </div>
        <% } %>
        <div class="confirm-item"><span>Gesamt (netto)</span><span><%= formatEuro(order?.total) %></span></div>
        <div class="confirm-item"><span>zzgl. 20% MwSt.</span><span><%= formatEuro(vatAmount(order?.total)) %></span></div>
        <div class="confirm-total"><strong>Gesamt (inkl. MwSt.):</strong> <strong><%= formatEuro(grossAmount(order?.total)) %></strong></div>
      </div>

      <div class="confirmation-actions">
        <a href="/shop" class="btn-blue">Weiter einkaufen</a>
        <% if (locals.user) { %><a href="/konto/bestellungen" class="btn-outline">Meine Bestellungen</a><% } %>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
