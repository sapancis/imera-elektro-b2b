<%- include('partials/header') %>

<style>
#maintenance-overlay {
  position: fixed; inset: 0; z-index: 99999;
  background: #0a0a0f;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; text-align: center;
  padding: 24px;
}
#maintenance-overlay .logo { font-size: 28px; font-weight: 800; letter-spacing: 3px; color: #fff; margin-bottom: 6px; }
#maintenance-overlay .logo span { color: #34C759; }
#maintenance-overlay .icon { font-size: 56px; margin: 28px 0 20px; }
#maintenance-overlay h1 { font-size: clamp(22px,5vw,38px); font-weight: 700; color: #fff; margin-bottom: 14px; line-height: 1.3; }
#maintenance-overlay p { font-size: clamp(14px,3vw,18px); color: #999; max-width: 500px; line-height: 1.7; margin-bottom: 32px; }
#maintenance-overlay .badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(52,199,89,.12); border: 1px solid rgba(52,199,89,.3);
  color: #34C759; border-radius: 999px; padding: 10px 24px;
  font-size: 15px; font-weight: 600;
}
#maintenance-overlay .dot {
  width: 8px; height: 8px; border-radius: 50%; background: #34C759;
  animation: pulse 1.4s ease-in-out infinite;
}
#maintenance-overlay .wa {
  margin-top: 28px;
  display: inline-flex; align-items: center; gap: 10px;
  background: #25D366; color: #fff; border-radius: 999px;
  padding: 13px 28px; font-size: 16px; font-weight: 600;
  text-decoration: none;
}
#maintenance-overlay .wa:hover { background: #1ebe5a; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
</style>

<div id="maintenance-overlay">
  <div class="logo">IMERA <span>ELEKTRO</span></div>
  <div class="icon">⚡</div>
  <h1>Wir bereiten uns für Sie vor!</h1>
  <p>Unser Shop wird gerade erneuert, um Ihnen noch besseren Service bieten zu können. Wir sind bald wieder für Sie da.</p>
  <div class="badge">
    <div class="dot"></div>
    In Kürze verfügbar
  </div>
  <a href="https://wa.me/436608514467" class="wa" target="_blank" rel="noopener">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    Jetzt per WhatsApp anfragen
  </a>
</div>

<main>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">✓ CE-ZERTIFIZIERT &nbsp;|&nbsp; DIREKTIMPORT TÜRKEI &nbsp;|&nbsp; AB 1 STÜCK</div>
      <h1>Elektrokomponenten 40-60%<br>unter österreichischem Marktpreis</h1>
      <p class="hero-sub">Kabelbinder, Kabelverschraubungen, Reihenklemmen & mehr – gleiche Qualität, direkt vom Hersteller, ohne Zwischenhändler</p>
      <div class="hero-btns">
        <a href="/shop" class="btn-green btn-lg">Zum Shop</a>
      </div>
      <div class="hero-trust">
        <span>✓ CE-zertifiziert</span>
        <span>✓ 1-2 Tage Lieferung</span>
        <span>✓ Keine MwSt.</span>
        <span>✓ Ab 1 Stück</span>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number"><%= stats.products %>+</div>
          <div class="stat-label">Produkte im Sortiment</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <div class="stat-number">40-60%</div>
          <div class="stat-label">Günstiger als Marktpreis</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <div class="stat-number">1-2</div>
          <div class="stat-label">Werktage Lieferzeit</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <div class="stat-number">CE</div>
          <div class="stat-label">Zertifizierte Qualität</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Preisvergleich -->
  <section class="section section-white">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">PREISVERGLEICH</div>
        <h2>Bis zu 72% günstiger als der Markt</h2>
        <p>Vergleichen Sie selbst – gleiche Qualität, deutlich niedrigere Preise</p>
      </div>
      <div class="comparison-grid">
        <% for (const p of featured) { %>
        <div class="comparison-card <%= p.badge === 'BESTSELLER' ? 'comparison-card--featured' : '' %>">
          <% if (p.badge) { %><div class="card-badge card-badge--<%= p.badge === 'BESTSELLER' ? 'green' : 'blue' %>"><%= p.badge %></div><% } %>
          <div class="text-center">
            <p class="product-cat-label"><%= p.cat_name %></p>
            <h3 class="comparison-product-name"><%= p.name %></h3>
            <div class="price-compare">
              <div class="price-ours">
                <div class="price-label">Bei uns</div>
                <div class="price-value price-green"><%= formatPrice(p.tiers[0]?.price) %></div>
              </div>
              <div class="price-arrow">→</div>
              <div class="price-market">
                <div class="price-label">Markt AT</div>
                <div class="price-value price-red price-strikethrough"><%= formatPrice(p.market_price_min) %>–<%= formatPrice(p.market_price_max) %></div>
              </div>
            </div>
            <div class="savings-badge">Sie sparen bis zu <%= savings(p.tiers[0]?.price, p.market_price_max) %>%</div>
            <% if (p.tiers.length > 1) { %>
            <div class="tier-hint">
              <div class="tier-hint-label">Staffelpreise verfügbar</div>
              <% for (const t of p.tiers.slice(1,2)) { %><div>Ab <%= t.min_qty %> Stk: <%= formatPrice(t.price) %></div><% } %>
            </div>
            <% } %>
            <a href="/shop/produkt/<%= p.slug %>" class="btn-blue btn-sm mt-1" style="display:block">Zum Produkt</a>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Kategorien -->
  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <h2>Unser Sortiment</h2>
        <p>Hochwertige Elektrokomponenten für Profis</p>
      </div>
      <div class="categories-grid">
        <% for (const cat of categories) { %>
        <a href="/shop?kategorie=<%= cat.slug %>" class="category-card">
          <div class="category-icon"><%= cat.icon %></div>
          <h3><%= cat.name %></h3>
          <p><%= cat.description %></p>
          <div class="category-footer">
            <span class="cat-link">Produkte ansehen →</span>
          </div>
        </a>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Neue Produkte -->
  <section class="section section-white">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">SORTIMENT</div>
        <h2>Aktuelle Produkte</h2>
        <p>Direkt verfügbar – sofort bestellbar</p>
      </div>
      <div class="products-grid">
        <% for (const p of newProducts) { %>
        <a href="/shop/produkt/<%= p.slug %>" class="product-card">
          <div class="product-img-wrap">
            <% if (p.image) { %>
            <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
            <% } else { %>
            <div class="product-img-placeholder">📦</div>
            <% } %>
            <% if (p.stock <= 0) { %><span class="product-badge product-badge--out">Ausverkauft</span><% } else if (p.featured) { %><span class="product-badge product-badge--hot">Bestseller</span><% } %>
          </div>
          <div class="product-info">
            <div class="product-cat"><%= p.cat_name %></div>
            <h3 class="product-name"><%= p.name %></h3>
            <% if (p.sku) { %><div class="product-sku">Art.-Nr. <%= p.sku %></div><% } %>
            <div class="product-footer">
              <% if (p.price_min) { %>
              <div class="product-price">ab <strong><%= formatEuro(p.price_min) %></strong></div>
              <% } %>
              <span class="product-cta">Details →</span>
            </div>
          </div>
        </a>
        <% } %>
      </div>
      <div style="text-align:center;margin-top:2.5rem">
        <a href="/shop" class="btn-blue btn-lg">Alle Produkte ansehen</a>
      </div>
    </div>
  </section>

  <!-- Für wen? -->
  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <h2>Für wen ist Imera Elektro?</h2>
        <p>Wir beliefern Profis aller Branchen</p>
      </div>
      <div class="target-grid">
        <div class="target-card"><div class="target-icon">⚡</div><h3>Elektriker</h3><p>Klein- und Mittelbetriebe, die regelmäßig Elektrokomponenten benötigen</p></div>
        <div class="target-card"><div class="target-icon">🏭</div><h3>Schaltschrankbauer</h3><p>Profis, die auf zuverlässige Reihenklemmen, DIN-Schienen und Kabelmanagement angewiesen sind</p></div>
        <div class="target-card"><div class="target-icon">🔧</div><h3>Industrie</h3><p>Wartungsabteilungen und Facility Management mit laufendem Bedarf</p></div>
        <div class="target-card"><div class="target-icon">🏪</div><h3>Händler</h3><p>Kleinere Elektrogroßhändler, die ihr Sortiment ergänzen möchten</p></div>
      </div>
    </div>
  </section>

  <!-- Wie funktioniert's -->
  <section class="section section-white">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">SO EINFACH</div>
        <h2>In 3 Schritten zum Produkt</h2>
        <p>Schnell, einfach und ohne Aufwand</p>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <div class="step-icon">🔍</div>
          <h3>Produkt wählen</h3>
          <p>Durchsuchen Sie unser Sortiment nach SKU oder Kategorie. Staffelpreise sind sofort sichtbar.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-card">
          <div class="step-num">2</div>
          <div class="step-icon">🛒</div>
          <h3>Bestellen</h3>
          <p>Einfach in den Warenkorb, Adresse eingeben, Zahlung per Überweisung oder Rechnung wählen.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-card">
          <div class="step-num">3</div>
          <div class="step-icon">📦</div>
          <h3>Lieferung erhalten</h3>
          <p>Ihre Bestellung wird innerhalb von 1-2 Werktagen direkt zu Ihnen geliefert.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Vorteile -->
  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <h2>Warum Imera Elektro?</h2>
        <p>Ihre Vorteile auf einen Blick</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon feature-icon--blue">✓</div>
          <h3>CE-zertifiziert</h3>
          <p>Alle Produkte sind EU-konform und entsprechen höchsten Qualitätsstandards</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon feature-icon--green">🚚</div>
          <h3>Schnelle Lieferung</h3>
          <p>Lager in Österreich für kurze Lieferzeiten innerhalb von 1-2 Werktagen</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon feature-icon--yellow">💰</div>
          <h3>Staffelpreise</h3>
          <p>Bereits ab 1 Stück bestellbar – je mehr Sie kaufen, desto günstiger wird es</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon feature-icon--purple">📋</div>
          <h3>Keine MwSt.</h3>
          <p>Als Kleinunternehmer geben wir die Steuerersparnis direkt an Sie weiter</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <div class="google-rating-header">
          <svg class="google-logo" width="28" height="28" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div>
            <div class="google-rating-score">
              <span class="google-score-num">5.0</span>
              <div class="google-stars">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
              </div>
            </div>
            <div class="google-rating-sub">Google Bewertungen</div>
          </div>
        </div>
      </div>

      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-card-header">
            <div class="testimonial-avatar" style="background:#1A73E8">MS</div>
            <div class="testimonial-meta">
              <strong>Markus S.</strong>
              <span>Elektriker · Wien</span>
            </div>
            <svg class="google-icon-sm" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div class="testimonial-stars-row">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            <span class="testimonial-date">vor 2 Wochen</span>
          </div>
          <p class="testimonial-text">Qualität ist genauso wie bei namhaften Herstellern – zum halben Preis. Wir bestellen jetzt regelmäßig Kabelbinder und Kabelschuhe. Sehr empfehlenswert!</p>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card-header">
            <div class="testimonial-avatar" style="background:#34A853">TK</div>
            <div class="testimonial-meta">
              <strong>Thomas K.</strong>
              <span>Schaltschrankbau · Graz</span>
            </div>
            <svg class="google-icon-sm" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div class="testimonial-stars-row">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            <span class="testimonial-date">vor 1 Monat</span>
          </div>
          <p class="testimonial-text">Lieferung kam in 3 Tagen, Reihenklemmen sind CE-zertifiziert und passen perfekt in unsere Schaltschränke. Werde definitiv wieder bestellen.</p>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card-header">
            <div class="testimonial-avatar" style="background:#EA4335">RF</div>
            <div class="testimonial-meta">
              <strong>Roland F.</strong>
              <span>Facility Management · Linz</span>
            </div>
            <svg class="google-icon-sm" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div class="testimonial-stars-row">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            <span class="testimonial-date">vor 3 Wochen</span>
          </div>
          <p class="testimonial-text">Staffelpreise sind sehr fair. Bei größeren Mengen spart man enorm. Der Kundenservice ist schnell und hilfsbereit. Klare Weiterempfehlung!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner-inner">
        <div class="cta-banner-text">
          <h2>Bereit zu sparen?</h2>
          <p>Fordern Sie jetzt kostenlos unsere vollständige Preisliste an oder starten Sie direkt mit dem Einkauf.</p>
        </div>
        <div class="cta-banner-actions">
          <a href="/shop" class="btn-white-solid btn-lg">Zum Shop</a>
          <a href="#preisliste" class="btn-outline-white btn-lg">Preisliste anfordern</a>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
