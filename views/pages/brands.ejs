<%- include('../partials/header') %>
<style>
  .brand-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:1rem; margin-top:1.5rem; }
  .brand-card { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.6rem;
    border:1px solid var(--border,#E5E7EB); border-radius:14px; padding:1.5rem 1rem; background:#fff; text-align:center;
    transition:border-color .2s, transform .2s; min-height:150px; }
  .brand-card:hover { border-color:#34C759; transform:translateY(-2px); }
  .brand-card img { max-height:52px; max-width:150px; width:auto; object-fit:contain; }
  .brand-card-name { font-weight:700; font-size:16px; color:#1D1D1F; }
  .brand-card-count { font-size:12px; color:#6B7280; }
  @media (max-width:480px){ .brand-grid { grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; } .brand-card{padding:1rem .5rem;min-height:120px} }
</style>
<main>
  <div class="container page-content">
    <h1>Marken &amp; Hersteller</h1>
    <p>Wir führen Produkte namhafter Hersteller für Elektroinstallation und Schaltschrankbau – alle CE-zertifiziert und normkonform.</p>

    <div class="brand-grid">
      <% for (const b of brands) { %>
      <a href="/marken/<%= b.slug %>" class="brand-card">
        <% if (b.logo) { %>
          <img src="<%= b.logo %>" alt="<%= b.name %> Logo" loading="lazy">
        <% } else { %>
          <div class="brand-card-name"><%= b.name %></div>
        <% } %>
        <% if (b.logo) { %><div class="brand-card-name" style="font-size:14px"><%= b.name %></div><% } %>
        <div class="brand-card-count"><%= b.cnt %> Produkt<%= b.cnt === 1 ? '' : 'e' %></div>
      </a>
      <% } %>
    </div>

    <% if (!brands.length) { %><p class="text-gray">Noch keine Marken angelegt.</p><% } %>
  </div>
</main>
<%- include('../partials/footer') %>
