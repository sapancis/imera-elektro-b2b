<%- include('../partials/header') %>
<style>
  .kat-group { border:1px solid var(--border,#E5E7EB); border-radius:14px; padding:1.25rem 1.5rem; margin-bottom:1rem; background:#fff; }
  .kat-head { display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:.9rem; }
  .kat-head img { max-height:32px; max-width:110px; object-fit:contain; }
  .kat-head h2 { margin:0; font-size:18px; }
  .kat-head a.kat-link { font-size:13px; color:#166534; }
</style>
<main>
  <div class="container page-content">
    <nav class="breadcrumb"><a href="/">Startseite</a> › Kataloge</nav>
    <h1>Kataloge &amp; Datenblätter</h1>
    <p>Alle technischen Unterlagen unserer Marken als PDF – Maße, Normen, Artikelnummern und Zubehör.</p>

    <% if (!groups.length) { %>
      <p class="text-gray">Derzeit stehen keine Kataloge zum Download bereit. <a href="/kontakt">Kontaktieren Sie uns</a> – wir senden Ihnen die gewünschten Unterlagen gerne zu.</p>
    <% } %>

    <% for (const g of groups) { %>
    <div class="kat-group">
      <div class="kat-head">
        <% if (g.logo) { %><img src="<%= g.logo %>" alt="<%= g.name %> Logo"><% } %>
        <h2><%= g.name %></h2>
        <a href="/marken/<%= g.slug %>" class="kat-link">Produkte ansehen →</a>
      </div>
      <div class="brand-cat-list">
        <% for (const c of g.items) { %>
        <a href="<%= c.file_url %>" target="_blank" rel="noopener">📄 <%= c.title %></a>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
