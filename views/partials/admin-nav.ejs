<aside class="admin-sidebar">
  <div class="admin-brand">
    <a href="/" style="color:white;text-decoration:none">IMERA ELEKTRO</a>
    <small>Admin Panel</small>
  </div>
  <nav class="admin-nav">
    <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">📊 Dashboard</a>
    <a href="/admin/produkte" class="<%= currentPath.includes('/admin/produkte') || currentPath.includes('/admin/kategorien') ? 'active' : '' %>">📦 Produkte</a>
    <a href="/admin/kategorien" class="<%= currentPath.includes('/admin/kategorien') ? 'active' : '' %>" style="padding-left:2.5rem;font-size:13px">└ Kategorien</a>
    <a href="/admin/bestellungen" class="<%= currentPath.includes('/admin/bestellungen') ? 'active' : '' %>">🛒 Bestellungen</a>
    <a href="/admin/kunden" class="<%= currentPath.includes('/admin/kunden') ? 'active' : '' %>">👥 Kunden</a>
    <a href="/admin/nachrichten" class="<%= currentPath.includes('/admin/nachrichten') ? 'active' : '' %>">✉️ Nachrichten</a>
    <a href="/admin/einstellungen" class="<%= currentPath.includes('/admin/einstellungen') ? 'active' : '' %>">⚙️ Einstellungen</a>
    <hr style="border-color:#374151;margin:1rem 0">
    <a href="/shop" target="_blank">🌐 Website ansehen</a>
    <form action="/konto/abmelden" method="POST" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" style="background:none;border:none;color:#9CA3AF;cursor:pointer;padding:0.75rem 1.5rem;width:100%;text-align:left;font-size:14px">🚪 Abmelden</button>
    </form>
  </nav>
</aside>
