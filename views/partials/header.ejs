<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- ─── Primary Meta ─────────────────────────────────────────────────── -->
  <title><%= title %> – Imera Elektro</title>
  <meta name="description" content="<%= locals.metaDesc || 'CE-zertifizierte Elektrokomponenten 40-60% günstiger als der österreichische Markt. Direktimport. Kabelbinder, Kabelverschraubungen, Reihenklemmen.' %>">
  <meta name="keywords" content="Elektrokomponenten, Kabelbinder, Kabelverschraubungen, Reihenklemmen, DIN-Schienen, CE-zertifiziert, Direktimport, günstig, Österreich">
  <meta name="author" content="Imera Elektro">
  <meta name="robots" content="<%= locals.noindex ? 'noindex,nofollow' : 'index,follow' %>">
  <link rel="canonical" href="https://www.imeragroup.com<%= locals.currentPath || '/' %>">

  <!-- ─── Open Graph (Facebook, LinkedIn, WhatsApp preview) ───────────── -->
  <meta property="og:type"        content="<%= locals.ogType || 'website' %>">
  <meta property="og:site_name"   content="Imera Elektro">
  <meta property="og:title"       content="<%= locals.ogTitle || title + ' – Imera Elektro' %>">
  <meta property="og:description" content="<%= locals.metaDesc || 'CE-zertifizierte Elektrokomponenten 40-60% günstiger als der österreichische Markt.' %>">
  <meta property="og:url"         content="https://www.imeragroup.com<%= locals.currentPath || '/' %>">
  <meta property="og:image"       content="<%= locals.ogImage || 'https://www.imeragroup.com/img/og-default.jpg' %>">
  <meta property="og:locale"      content="de_AT">

  <!-- ─── Twitter / X Card ────────────────────────────────────────────── -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= locals.ogTitle || title + ' – Imera Elektro' %>">
  <meta name="twitter:description" content="<%= locals.metaDesc || 'CE-zertifizierte Elektrokomponenten 40-60% günstiger als der österreichische Markt.' %>">
  <meta name="twitter:image"       content="<%= locals.ogImage || 'https://www.imeragroup.com/img/og-default.jpg' %>">

  <!-- ─── JSON-LD Structured Data ─────────────────────────────────────── -->
  <% if (!locals.noJsonLd) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "OnlineStore",
    "name": "Imera Elektro",
    "description": "CE-zertifizierte Elektrokomponenten 40-60% günstiger als der österreichische Markt. Direktimport.",
    "url": "https://www.imeragroup.com",
    "telephone": "+43660851446​7",
    "email": "info@imeragroup.com",
    "logo": "https://www.imeragroup.com/favicon.svg",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+43660851446​7",
      "contactType": "customer service",
      "availableLanguage": ["German"],
      "contactOption": "TollFree"
    },
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AT"
    },
    "sameAs": [],
    "priceRange": "€€",
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Bank Transfer, Invoice"<% if (locals.productJsonLd) { %>,
    "offers": <%- locals.productJsonLd %><% } %>
  }
  </script>
  <% } %>
  <% if (locals.breadcrumbJsonLd) { %>
  <script type="application/ld+json"><%- locals.breadcrumbJsonLd %></script>
  <% } %>
  <% if (locals.productJsonLd) { %>
  <script type="application/ld+json"><%- locals.productJsonLd %></script>
  <% } %>

  <!-- ─── Favicon ──────────────────────────────────────────────────────── -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="alternate icon" href="/favicon.svg">

  <!-- ─── Styles ───────────────────────────────────────────────────────── -->
  <link rel="stylesheet" href="/css/style.css?v=10">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap">
  <% if (locals.gaId) { %>
  <script>window._gaId = '<%= locals.gaId %>';</script>
  <% } %>
</head>
<body>

<% if (locals.flash) { %>
<div class="flash flash-<%= flash.type %>">
  <span><%= flash.message %></span>
  <button onclick="this.parentElement.remove()">×</button>
</div>
<% } %>

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="logo">IMERA ELEKTRO</a>
        <nav class="main-nav" id="mainNav">
          <a href="/shop" class="<%= (locals.currentPath || '').startsWith('/shop') ? 'active' : '' %>">Shop</a>
          <a href="/ueber-uns" class="<%= (locals.currentPath || '') === '/ueber-uns' ? 'active' : '' %>">Über uns</a>
          <a href="/kontakt" class="<%= (locals.currentPath || '') === '/kontakt' ? 'active' : '' %>">Kontakt</a>
          <a href="/faq" class="<%= (locals.currentPath || '') === '/faq' ? 'active' : '' %>">FAQ</a>
        </nav>
      </div>
      <div class="header-right">
        <% if (locals.user) { %>
          <a href="/konto" class="btn-header-link" title="Mein Konto">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            <span class="header-link-text"><%= user.name?.split(' ')[0] || 'Konto' %></span>
          </a>
          <% if (user.role === 'admin') { %><a href="/admin" class="btn-header-link">Admin</a><% } %>
        <% } else { %>
          <a href="/konto/login" class="btn-header-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            <span class="header-link-text">Anmelden</span>
          </a>
        <% } %>
        <a href="/merkliste" class="btn-header-link" title="Merkliste">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <% if ((locals.merklisteCount || 0) > 0) { %><span class="cart-badge merkliste-badge"><%= locals.merklisteCount %></span><% } %>
        </a>
        <a href="/vergleich" class="btn-header-link" title="Vergleichsliste">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        </a>
        <a href="/warenkorb" class="btn-cart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <% if ((locals.cartCount || 0) > 0) { %><span class="cart-badge"><%= locals.cartCount %></span><% } %>
        </a>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
