<%- include('partials/header') %>

<main>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Startseite</a> › <a href="/shop">Shop</a> › <a href="/shop?kategorie=<%= product.cat_slug %>"><%= product.cat_name %></a> › <%= product.name %>
    </nav>

    <div class="product-detail-grid">
      <!-- Image Gallery -->
      <div class="product-gallery">
        <div class="gallery-main">
          <% if (product.image) { %>
            <img src="<%= product.image %>" alt="<%= product.name %>" id="mainImage">
          <% } else { %>
            <div class="gallery-placeholder"><%= product.cat_name === 'Kabelbinder & Zubehör' ? '🔗' : product.cat_name === 'Kabelverschraubungen' ? '🔧' : product.cat_name === 'Reihenklemmen' ? '⚡' : '📦' %></div>
          <% } %>
        </div>
        <div class="gallery-thumbs">
          <% if (product.image) { %>
          <div class="gallery-thumb active" onclick="document.getElementById('mainImage').src='<%= product.image %>';document.querySelectorAll('.gallery-thumb').forEach(t=>t.classList.remove('active'));this.classList.add('active')">
            <img src="<%= product.image %>" alt="<%= product.name %> – Hauptbild">
          </div>
          <% } %>
          <% for (let gi = 0; gi < product.imagesArr.length; gi++) { %>
          <div class="gallery-thumb" onclick="document.getElementById('mainImage').src='<%= product.imagesArr[gi] %>';document.querySelectorAll('.gallery-thumb').forEach(t=>t.classList.remove('active'));this.classList.add('active')">
            <img src="<%= product.imagesArr[gi] %>" alt="<%= product.name %> – Bild <%= gi + 2 %>">
          </div>
          <% } %>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info">
        <% if (product.badge) { %><div class="product-badge-detail badge-green"><%= product.badge %></div><% } %>
        <h1 class="product-detail-title"><%= product.name %></h1>
        <% if (product.short_description) { %><p class="product-short-desc"><%= product.short_description %></p><% } %>
        <p class="product-detail-meta">
          <% if (product.sku) { %>Art.-Nr.: <strong><%= product.sku %></strong><% } %>
          <% if (product.sku) { %> &nbsp;|&nbsp; <% } %>
          Lagerbestand: <strong class="<%= product.stock > 0 ? 'text-green' : 'text-red' %>"><%= product.stock > 0 ? product.stock + ' Stück verfügbar' : 'Nicht auf Lager' %></strong>
          <% if (product.min_order_qty > 1) { %> &nbsp;|&nbsp; Min. Bestellung: <strong><%= product.min_order_qty %> Stk.</strong><% } %>
        </p>

        <% if (product.market_price_min && product.market_price_max) { %>
        <div class="market-price-box">
          <div class="market-price-label">Marktpreis in Österreich</div>
          <div class="market-price-row">
            <span class="price-red price-strikethrough"><%= formatPrice(product.market_price_min) %> – <%= formatPrice(product.market_price_max) %></span>
            <span class="savings-text">Sie sparen bis zu <%= savings(product.tiers[0]?.price, product.market_price_max) %>%</span>
          </div>
        </div>
        <% } %>

        <!-- Tier Price Box -->
        <div class="tier-box">
          <h3>Staffelpreise – Je mehr, desto günstiger</h3>
          <div class="tier-options" id="tierOptions">
            <% for (let i = 0; i < product.tiers.length; i++) { %>
            <label class="tier-option-row <%= i === 0 ? 'selected' : '' %>" data-tier-idx="<%= i %>">
              <input type="radio" name="tier" value="<%= i %>" <%= i === 0 ? 'checked' : '' %> style="margin-right:10px">
              <div class="tier-option-info">
                <div class="tier-option-range"><%= product.tiers[i].label || product.tiers[i].min_qty + '–' + (product.tiers[i].max_qty || '∞') + ' Stück' %></div>
                <div class="tier-option-sub"><%= i === 0 ? 'Ideal für Kleinbedarf' : i === 1 ? 'Beliebteste Option' : 'Bester Preis für Großabnehmer' %></div>
              </div>
              <div class="tier-option-price">
                <span class="tier-price-val" style="color:<%= i === 0 ? '#1E3A8A' : '#10B981' %>"><%= formatPrice(product.tiers[i].price) %></span>
                <small>pro Stück</small>
              </div>
            </label>
            <% } %>
          </div>

          <div class="qty-section">
            <div class="qty-label">Bestellmenge eingeben</div>
            <div class="qty-row">
              <input type="number" id="detailQty" value="1" min="1" class="qty-input-lg">
              <button onclick="adjustQty(10)" class="btn-qty-adj">+10</button>
              <button onclick="adjustQty(100)" class="btn-qty-adj">+100</button>
            </div>

            <div class="price-summary" id="priceSummary">
              <div class="price-summary-row">
                <span>Gesamtpreis</span>
                <span class="price-total-big" id="totalPrice"><%= formatPrice(product.tiers[0]?.price) %></span>
              </div>
              <div class="price-summary-note" id="priceNote">1 Stück × <%= formatPrice(product.tiers[0]?.price) %></div>
            </div>

            <div class="tip-box" id="tipBox" style="display:none"></div>

            <% if (product.stock > 0) { %>
            <button class="btn-add-cart-lg btn-blue-full" id="addToCartBtn" data-product-id="<%= product.id %>" data-csrf="<%= csrfToken %>">In den Warenkorb legen</button>
            <a href="/warenkorb" class="btn-add-cart-lg btn-outline-full" style="text-align:center;display:block;margin-top:8px;padding:14px;border:2px solid #1E3A8A;border-radius:8px;color:#1E3A8A;text-decoration:none;font-weight:500">Sofort kaufen (zum Warenkorb)</a>
            <% } else { %>
            <button class="btn-add-cart-lg btn-disabled" disabled>Nicht auf Lager</button>
            <% } %>
          </div>
        </div>

        <div class="product-actions-row" style="margin-top:12px">
          <button class="btn-merken" id="merkenBtn" data-product-id="<%= product.id %>" data-csrf="<%= csrfToken %>">♥ Merken</button>
          <button class="btn-vergleichen" id="vergleichenBtn" data-product-id="<%= product.id %>" data-csrf="<%= csrfToken %>">⚖ Vergleichen</button>
          <button class="btn-share-cart" id="shareCartBtn" data-csrf="<%= csrfToken %>" title="Warenkorb speichern & teilen">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
            Teilen
          </button>
        </div>
        <div id="shareCartResult" style="display:none;margin-top:8px;font-size:13px;background:#F0FDF4;border:1px solid #BBF7D0;border-radius:8px;padding:8px 12px">
          <strong>Link zum Teilen:</strong>
          <input type="text" id="shareCartLink" readonly style="border:none;background:transparent;width:calc(100% - 80px);font-size:12px;outline:none">
          <button onclick="navigator.clipboard.writeText(document.getElementById('shareCartLink').value);this.textContent='✓ Kopiert!';setTimeout(()=>this.textContent='Kopieren',2000)" style="font-size:12px;background:#10B981;color:#fff;border:none;border-radius:4px;padding:3px 8px;cursor:pointer">Kopieren</button>
        </div>

        <div class="trust-row">
          <div class="trust-item"><span>✓</span><small>CE-zertifiziert</small></div>
          <div class="trust-item"><span>🚚</span><small><%= product.delivery_time || '2–5 Tage Lieferzeit' %></small></div>
          <div class="trust-item"><span>↩</span><small>14 Tage Rückgabe</small></div>
          <% if (product.weight) { %><div class="trust-item"><span>⚖</span><small><%= product.weight %></small></div><% } %>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="product-tabs">
      <div class="tab-nav">
        <button class="tab-btn tab-active" onclick="showTab('details', this)">Produktdetails</button>
        <button class="tab-btn" onclick="showTab('specs', this)">Technische Daten</button>
        <button class="tab-btn" onclick="showTab('why', this)">Warum bei uns?</button>
        <button class="tab-btn" onclick="showTab('reviews', this)">
          Bewertungen
          <% if (reviewStats.count > 0) { %>
            <span class="tab-badge"><%= reviewStats.count %></span>
          <% } %>
        </button>
      </div>

      <div class="tab-content tab-active" id="tab-details">
        <div class="tab-grid">
          <div>
            <h2>Produktbeschreibung</h2>
            <p class="product-description"><%= product.description %></p>

            <% if (product.appsArr.length) { %>
            <h3>Anwendungsbereiche</h3>
            <ul class="app-list">
              <% for (const app of product.appsArr) { %><li><%= app %></li><% } %>
            </ul>
            <% } %>
          </div>
          <div>
            <div class="why-box">
              <h3>Warum bei uns kaufen?</h3>
              <ul class="why-list">
                <li>✓ Direktimport vom Hersteller</li>
                <li>✓ 40-72% günstiger als Markt</li>
                <li>✓ CE-zertifizierte Qualität</li>
                <li>✓ Schnelle Lieferung aus AT</li>
                <li>✓ Persönlicher Support</li>
              </ul>
            </div>
            <div class="contact-box">
              <h3>Haben Sie Fragen?</h3>
              <p>Unser Team berät Sie gerne bei der Auswahl.</p>
              <a href="tel:+436608514467" class="btn-outline-sm">📞 Jetzt anrufen</a>
              <a href="/kontakt" class="btn-outline-sm">📧 E-Mail senden</a>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-content" id="tab-specs" style="display:none">
        <% if (product.specsArr.length) { %>
        <table class="specs-table">
          <% for (const [key, val] of product.specsArr) { %>
          <tr><td><%= key %></td><td><%= val %></td></tr>
          <% } %>
        </table>
        <% } %>
      </div>

      <div class="tab-content" id="tab-why" style="display:none">
        <div class="why-content">
          <h2>Direktimport = Ihr Vorteil</h2>
          <p>Durch unseren direkten Import von CE-zertifizierten türkischen Herstellern (ONKA, TORK) sparen wir Zwischenhändlermargen ein und geben die Ersparnis vollständig an Sie weiter. Gleiche Qualität, deutlich bessere Preise.</p>
          <div class="comparison-logos">
            <div><strong>Statt bei:</strong> Schrack, Würth, Sonepar, Rexel</div>
            <div><strong>Kaufen Sie direkt:</strong> 40–72% günstiger</div>
          </div>
        </div>
      </div>

      <!-- Bewertungen Tab -->
      <div class="tab-content" id="tab-reviews" style="display:none">
        <div class="reviews-layout">

          <!-- Summary -->
          <div class="reviews-summary">
            <% if (reviewStats.count > 0) { %>
            <div class="review-score-big"><%= reviewStats.avg %></div>
            <div class="review-stars-big">
              <% for (let i=1; i<=5; i++) { %>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="<%= i <= Math.round(reviewStats.avg) ? '#FBBC05' : '#E5E7EB' %>" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <% } %>
            </div>
            <div class="review-count-text">Basierend auf <%= reviewStats.count %> Bewertung<%= reviewStats.count !== 1 ? 'en' : '' %></div>
            <% } else { %>
            <div class="review-empty-hint">
              <div style="font-size:2rem;margin-bottom:0.5rem">⭐</div>
              <p>Noch keine Bewertungen für dieses Produkt.</p>
              <p style="font-size:13px;color:#9CA3AF">Seien Sie der Erste!</p>
            </div>
            <% } %>
          </div>

          <!-- Review List -->
          <div class="reviews-list">
            <% for (const rv of reviews) { %>
            <div class="review-card">
              <div class="review-card-header">
                <div class="review-avatar" style="background:<%= ['#1E3A8A','#10B981','#F59E0B','#EF4444','#8B5CF6'][rv.id % 5] %>">
                  <%= (rv.author_name || 'K').charAt(0).toUpperCase() %>
                </div>
                <div class="review-meta">
                  <strong><%= rv.author_name %><%= rv.company ? ' · ' + rv.company : '' %></strong>
                  <span><%= new Date(rv.created_at).toLocaleDateString('de-AT', { year:'numeric', month:'long', day:'numeric' }) %></span>
                </div>
                <% if (rv.verified_purchase) { %>
                <div class="review-verified">✓ Verifizierter Kauf</div>
                <% } %>
              </div>
              <div class="review-stars">
                <% for (let i=1; i<=5; i++) { %>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="<%= i <= rv.rating ? '#FBBC05' : '#E5E7EB' %>" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <% } %>
              </div>
              <p class="review-text"><%= rv.text %></p>
            </div>
            <% } %>
          </div>

          <!-- Review Form -->
          <div class="review-form-wrap">
            <h3>Produkt bewerten</h3>
            <% if (!locals.user) { %>
            <div class="review-login-note">
              <a href="/konto/login">Anmelden</a>, um eine Bewertung zu hinterlassen.
            </div>
            <% } else if (alreadyReviewed) { %>
            <div class="review-login-note" style="color:#10B981">✓ Sie haben dieses Produkt bereits bewertet. Vielen Dank!</div>
            <% } else { %>
            <form id="reviewForm" class="review-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="star-picker" id="starPicker">
                <% for (let i=1; i<=5; i++) { %>
                <svg class="star-pick" data-val="<%= i %>" width="32" height="32" viewBox="0 0 24 24" fill="#E5E7EB" xmlns="http://www.w3.org/2000/svg" style="cursor:pointer;transition:fill .15s"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <% } %>
              </div>
              <input type="hidden" name="rating" id="ratingInput" value="0">
              <div class="form-group">
                <label>Ihre Bewertung *</label>
                <textarea name="text" id="reviewText" rows="4" placeholder="Teilen Sie Ihre Erfahrungen mit diesem Produkt (mindestens 10 Zeichen)…" required></textarea>
              </div>
              <button type="submit" class="btn-green btn-full" id="reviewSubmitBtn">Bewertung einreichen</button>
              <div id="reviewMsg" style="display:none;margin-top:10px;font-size:14px;padding:10px;border-radius:8px"></div>
            </form>
            <% } %>
          </div>

        </div>
      </div>
    </div>

    <!-- Related Products -->
    <% if (related.length > 0) { %>
    <section class="related-products">
      <h2>Ähnliche Produkte</h2>
      <div class="product-grid product-grid-sm">
        <% for (const rp of related) { %>
        <div class="product-card">
          <a href="/shop/produkt/<%= rp.slug %>" class="product-card-image">
            <div class="product-placeholder">📦</div>
          </a>
          <div class="product-card-body">
            <h3 class="product-name"><a href="/shop/produkt/<%= rp.slug %>"><%= rp.name %></a></h3>
            <div class="tier-hint"><span class="price-green"><%= formatPrice(rp.tiers[0]?.price) %></span> / Stück</div>
          </div>
        </div>
        <% } %>
      </div>
    </section>
    <% } %>
  </div>
</main>

<script>
const productId = '<%= product.id %>';
const tiers = <%- JSON.stringify(product.tiers) %>;

function adjustQty(n) {
  const inp = document.getElementById('detailQty');
  inp.value = Math.max(1, parseInt(inp.value || 0) + n);
  updatePrice();
}

document.getElementById('detailQty')?.addEventListener('input', updatePrice);

function updatePrice() {
  const qty = parseInt(document.getElementById('detailQty').value) || 1;
  fetch(`/shop/api/preis/${productId}?qty=${qty}`)
    .then(r => r.json()).then(data => {
      if (!data.ok) return;
      document.getElementById('totalPrice').textContent = data.total.toString().replace('.', ',') + '€';
      document.getElementById('priceNote').textContent = qty + ' Stück × ' + data.unitPrice.toString().replace('.', ',') + '€';
      const tip = document.getElementById('tipBox');
      if (data.nextTier) {
        tip.style.display = 'block';
        const diff = data.nextTier.min_qty - qty;
        tip.textContent = `💡 Tipp: Bestellen Sie ${diff} weitere Stück und sparen Sie zusätzlich – dann nur ${data.nextTier.price.toFixed(3).replace('.',',')}€/Stk`;
      } else { tip.style.display = 'none'; }
      highlightTier(qty);
    });
}

function highlightTier(qty) {
  document.querySelectorAll('.tier-option-row').forEach((row, i) => {
    const t = tiers[i];
    const inRange = qty >= t.min_qty && (t.max_qty === null || qty <= t.max_qty);
    row.classList.toggle('selected', inRange);
    if (inRange) row.querySelector('input').checked = true;
  });
}

document.getElementById('addToCartBtn')?.addEventListener('click', function() {
  const qty = parseInt(document.getElementById('detailQty').value) || 1;
  const csrf = this.dataset.csrf;
  fetch('/warenkorb/hinzufuegen', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `product_id=${productId}&qty=${qty}&_csrf=${encodeURIComponent(csrf)}`
  }).then(r => r.json()).then(d => {
    if (d.ok) {
      document.querySelectorAll('.cart-badge').forEach(b => b.textContent = d.cartCount);
      const toast = document.getElementById('cartToast');
      document.getElementById('cartToastMsg').textContent = d.message;
      toast.style.display = 'block';
      setTimeout(() => toast.style.display = 'none', 3000);
    }
  });
});

function showTab(id, btn) {
  document.querySelectorAll('.tab-content').forEach(t => { t.style.display = 'none'; t.classList.remove('tab-active'); });
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-active'));
  document.getElementById('tab-' + id).style.display = 'block';
  btn.classList.add('tab-active');
}

updatePrice();

// ─── Share Cart ───────────────────────────────────────────────────────────
document.getElementById('shareCartBtn')?.addEventListener('click', function() {
  fetch('/warenkorb/speichern', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: '_csrf=' + encodeURIComponent(this.dataset.csrf)
  }).then(r => r.json()).then(d => {
    if (d.ok) {
      document.getElementById('shareCartResult').style.display = 'block';
      document.getElementById('shareCartLink').value = d.link;
    }
  });
});

// ─── Star Picker ──────────────────────────────────────────────────────────
(function() {
  const picker = document.getElementById('starPicker');
  if (!picker) return;
  const stars = picker.querySelectorAll('.star-pick');
  let selected = 0;

  function paint(n, hover) {
    stars.forEach((s, i) => {
      s.setAttribute('fill', i < n ? '#FBBC05' : (hover ? '#FDE68A' : '#E5E7EB'));
    });
  }

  stars.forEach((s, i) => {
    s.addEventListener('mouseenter', () => paint(i + 1, true));
    s.addEventListener('mouseleave', () => paint(selected, false));
    s.addEventListener('click', () => {
      selected = i + 1;
      document.getElementById('ratingInput').value = selected;
      paint(selected, false);
    });
  });

  document.getElementById('reviewForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const rating = document.getElementById('ratingInput').value;
    const text = document.getElementById('reviewText').value.trim();
    const msg = document.getElementById('reviewMsg');
    const btn = document.getElementById('reviewSubmitBtn');
    if (!rating || rating === '0') { msg.style.display='block'; msg.style.background='#FEF2F2'; msg.style.color='#DC2626'; msg.textContent='Bitte wählen Sie eine Sternebewertung.'; return; }
    btn.disabled = true; btn.textContent = 'Wird eingereicht…';

    fetch('/shop/produkt/<%= product.slug %>/bewertung', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: `rating=${rating}&text=${encodeURIComponent(text)}&_csrf=${encodeURIComponent('<%= csrfToken %>')}`
    }).then(r => r.json()).then(d => {
      msg.style.display = 'block';
      msg.style.background = d.ok ? '#ECFDF5' : '#FEF2F2';
      msg.style.color = d.ok ? '#059669' : '#DC2626';
      msg.textContent = d.message;
      if (d.ok) { document.getElementById('reviewForm').style.display = 'none'; }
      btn.disabled = false; btn.textContent = 'Bewertung einreichen';
    });
  });
})();
</script>

<%- include('partials/footer') %>
