<%- include('partials/header') %>

<main>
  <div class="container shop-layout">

    <!-- Sidebar Filter -->
    <aside class="shop-sidebar">
      <div class="filter-box">
        <button type="button" class="filter-toggle-btn" id="filterToggle">
          <span>🔍 Filter</span><span class="ft-arrow">▼</span>
        </button>
        <div class="shop-filter-body" id="filterBody">
          <h3 class="filter-desktop-h">Filter</h3>
          <form action="/shop" method="GET" id="filterForm">
            <div class="filter-group">
              <div class="filter-label">Kategorie</div>
              <label class="filter-option">
                <input type="radio" name="kategorie" value="" <%= !filters.kategorie ? 'checked' : '' %> onchange="this.form.submit()">
                <span class="filter-text">Alle</span>
                <span class="filter-count">(<%= allCount %>)</span>
              </label>
              <% for (const cat of categories) { %>
              <label class="filter-option">
                <input type="radio" name="kategorie" value="<%= cat.slug %>" <%= filters.kategorie === cat.slug ? 'checked' : '' %> onchange="this.form.submit()">
                <span class="filter-text"><%= cat.name %></span>
                <span class="filter-count">(<%= cat.cnt %>)</span>
              </label>
              <% } %>
            </div>

            <div class="filter-group">
              <div class="filter-label">Preis</div>
              <% const preisList = Array.isArray(filters.preis) ? filters.preis : (filters.preis ? [filters.preis] : []); %>
              <label class="filter-option"><input type="checkbox" name="preis" value="under010" <%= preisList.includes('under010') ? 'checked' : '' %> onchange="this.form.submit()"> Unter 0,10€</label>
              <label class="filter-option"><input type="checkbox" name="preis" value="010to050" <%= preisList.includes('010to050') ? 'checked' : '' %> onchange="this.form.submit()"> 0,10€ – 0,50€</label>
              <label class="filter-option"><input type="checkbox" name="preis" value="050to100" <%= preisList.includes('050to100') ? 'checked' : '' %> onchange="this.form.submit()"> 0,50€ – 1,00€</label>
              <label class="filter-option"><input type="checkbox" name="preis" value="over100" <%= preisList.includes('over100') ? 'checked' : '' %> onchange="this.form.submit()"> Über 1,00€</label>
            </div>

            <div class="filter-group">
              <div class="filter-label">Verfügbarkeit</div>
              <label class="filter-option">
                <input type="checkbox" name="verfuegbar" value="1" <%= filters.verfuegbar === '1' ? 'checked' : '' %> onchange="this.form.submit()"> Nur auf Lager
              </label>
            </div>

            <% if (sizes && sizes.length > 0) { %>
            <div class="filter-group">
              <div class="filter-label">Größe</div>
              <% const selectedSizes = Array.isArray(filters.groesse) ? filters.groesse : (filters.groesse ? [filters.groesse] : []); %>
              <% for (const s of sizes) { %>
              <label class="filter-option">
                <input type="checkbox" name="groesse" value="<%= s %>" <%= selectedSizes.includes(s) ? 'checked' : '' %> onchange="this.form.submit()"> <%= s %>
              </label>
              <% } %>
            </div>
            <% } %>

            <input type="hidden" name="sort" value="<%= filters.sort %>">
            <a href="/shop" class="btn-reset">Filter zurücksetzen</a>
          </form>
        </div>
      </div>
    </aside>

    <!-- Product Grid -->
    <div class="shop-content">
      <div class="shop-toolbar">
        <div class="shop-count"><%= pagination.total %> Produkte gefunden</div>
        <select onchange="location.href='/shop?'+new URLSearchParams({...Object.fromEntries(new URLSearchParams(location.search)),sort:this.value})" class="sort-select">
          <option value="popular" <%= filters.sort==='popular' ? 'selected' : '' %>>Sortieren nach Beliebtheit</option>
          <option value="price_asc" <%= filters.sort==='price_asc' ? 'selected' : '' %>>Preis aufsteigend</option>
          <option value="price_desc" <%= filters.sort==='price_desc' ? 'selected' : '' %>>Preis absteigend</option>
          <option value="name_az" <%= filters.sort==='name_az' ? 'selected' : '' %>>Name A–Z</option>
        </select>
      </div>

      <!-- Trust Strip -->
      <div class="trust-bar">
        <div class="trust-bar-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>Rechnung für Geschäftskunden</span></div>
        <div class="trust-bar-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>14 Tage Rückgaberecht</span></div>
        <div class="trust-bar-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>Versand aus Österreich</span></div>
        <div class="trust-bar-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>CE-zertifizierte Produkte</span></div>
      </div>

      <p class="shop-shipping-note" style="margin:0 0 1rem;font-size:13px;color:#6B7280">🚚 Versandkosten werden im Checkout berechnet — gratis ab 200 € netto.</p>

      <div class="product-grid">
        <% for (const p of products) { %>
        <div class="product-card <%= p.stock === 0 ? 'product-card--sold-out' : '' %>">
          <a href="/shop/produkt/<%= p.slug %>" class="product-card-image">
            <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
            <% } else { %>
              <div class="product-placeholder"><%= p.cat_name === 'Kabelbinder & Zubehör' ? '🔗' : p.cat_name === 'Kabelverschraubungen' ? '🔧' : p.cat_name === 'Reihenklemmen' ? '⚡' : '📦' %></div>
            <% } %>
            <% if (p.stock === 0) { %>
              <div class="sold-out-overlay">
                <span>Ausverkauft</span>
              </div>
            <% } else { %>
              <button class="quickview-btn" data-slug="<%= p.slug %>" title="Schnellansicht">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                Schnellansicht
              </button>
            <% } %>
          </a>
          <div class="product-card-body">
            <h3 class="product-name"><a href="/shop/produkt/<%= p.slug %>"><%= p.name %></a></h3>
            <% if (p.sku) { %><p class="product-sku">Art.-Nr.: <%= p.sku %></p><% } %>
            <% if (p.description) { %><p class="product-short-desc"><%= p.description.slice(0,80) %><%= p.description.length > 80 ? '…' : '' %></p><% } %>

            <div class="tier-table">
              <div class="tier-table-label">Staffelpreise</div>
              <div class="tier-table-row">
                <% for (let ti = 0; ti < p.tiers.length; ti++) { %>
                <div>
                  <div class="tier-qty">Ab <%= p.tiers[ti].min_qty %> Stk</div>
                  <div class="tier-price <%= ti > 0 ? 'tier-price--green' : '' %>"><%= formatPrice(p.tiers[ti].price) %></div>
                </div>
                <% } %>
              </div>
            </div>

            <div class="product-order-row">
              <input type="number" class="qty-input" value="1" min="1" id="qty-<%= p.id %>">
              <% if (p.stock > 0) { %>
              <button class="btn-add-cart" data-product-id="<%= p.id %>" data-qty-id="qty-<%= p.id %>" data-csrf="<%= csrfToken %>">In den Warenkorb</button>
              <% } else { %>
              <button class="btn-add-cart btn-disabled" disabled>Ausverkauft</button>
              <% } %>
            </div>

            <div class="product-actions-row">
              <button class="btn-merken" data-product-id="<%= p.id %>" data-csrf="<%= csrfToken %>" title="Merken">♥ Merken</button>
              <button class="btn-vergleichen" data-product-id="<%= p.id %>" data-csrf="<%= csrfToken %>" title="Vergleichen">⚖ Vergleichen</button>
            </div>

            <div class="product-stock <%= p.stock > 0 ? 'stock-in' : 'stock-out' %>">
              <%= p.stock > 0 ? '✓ ' + p.stock + ' Stück auf Lager' : '⚠ Nicht auf Lager' %>
            </div>
          </div>
        </div>
        <% } %>
      </div>

      <% if (pagination.totalPages > 1) { %>
      <div class="pagination">
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
        <a href="/shop?page=<%= i %>&kategorie=<%= filters.kategorie||'' %>&sort=<%= filters.sort %>" class="page-btn <%= i === pagination.page ? 'page-btn--active' : '' %>"><%= i %></a>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Schnell-Bestellformular -->
  <div class="schnell-section">
    <div class="schnell-inner">
      <div class="schnell-header">
        <div class="schnell-icon">⚡</div>
        <div>
          <h2>Schnellbestellung</h2>
          <p>Artikelnummer bekannt? Direkt in den Warenkorb — ohne Suche.</p>
        </div>
      </div>
      <div class="schnell-body">
        <div class="schnell-col-labels">
          <span>Artikelnummer (SKU)</span>
          <span>Menge</span>
          <span></span>
        </div>
        <div id="schnellLines">
          <div class="schnell-line">
            <input type="text" class="schnell-sku" placeholder="z.B. TRK-200-45B" autocomplete="off">
            <input type="number" class="schnell-qty" value="100" min="1" placeholder="100">
            <button type="button" class="schnell-remove" title="Zeile entfernen">✕</button>
          </div>
        </div>
        <div class="schnell-actions">
          <button type="button" id="schnellAddLine" class="schnell-add-btn">+ Zeile hinzufügen</button>
          <button type="button" id="schnellSubmit" class="schnell-submit-btn">In den Warenkorb</button>
        </div>
        <div id="schnellMsg" class="schnell-msg" style="display:none"></div>
      </div>
    </div>
  </div>
</main>

<!-- Schnellansicht Modal -->
<div id="quickviewOverlay" class="qv-overlay" style="display:none" role="dialog" aria-modal="true" aria-label="Schnellansicht">
  <div class="qv-modal">
    <button class="qv-close" id="qvClose" aria-label="Schließen">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="qv-body">
      <div class="qv-image-col">
        <div class="qv-image-wrap" id="qvImageWrap">
          <div class="qv-loading">⟳</div>
        </div>
      </div>
      <div class="qv-info-col" id="qvInfoCol">
        <div class="qv-loading-full">Wird geladen…</div>
      </div>
    </div>
  </div>
</div>

<script>
// Schnell-Bestellformular
(function() {
  const linesEl   = document.getElementById('schnellLines');
  const addBtn    = document.getElementById('schnellAddLine');
  const submitBtn = document.getElementById('schnellSubmit');
  const msgEl     = document.getElementById('schnellMsg');

  function removeLine(btn) {
    const lines = linesEl.querySelectorAll('.schnell-line');
    if (lines.length > 1) btn.closest('.schnell-line').remove();
  }

  function addLine() {
    const div = document.createElement('div');
    div.className = 'schnell-line';
    div.innerHTML = `<input type="text" class="schnell-sku" placeholder="Artikelnummer" autocomplete="off">
      <input type="number" class="schnell-qty" value="100" min="1" placeholder="Menge">
      <button type="button" class="schnell-remove" title="Entfernen">✕</button>`;
    div.querySelector('.schnell-remove').addEventListener('click', function(){ removeLine(this); });
    linesEl.appendChild(div);
    div.querySelector('.schnell-sku').focus();
  }

  linesEl.querySelector('.schnell-remove').addEventListener('click', function(){ removeLine(this); });
  addBtn.addEventListener('click', addLine);

  submitBtn.addEventListener('click', () => {
    const lines = [];
    linesEl.querySelectorAll('.schnell-line').forEach(row => {
      const sku = row.querySelector('.schnell-sku').value.trim();
      const qty = parseInt(row.querySelector('.schnell-qty').value) || 1;
      if (sku) lines.push({ sku, qty });
    });
    if (!lines.length) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird hinzugefügt…';

    const csrf = '<%= csrfToken %>';
    fetch('/warenkorb/schnellbestellung', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: `lines=${encodeURIComponent(JSON.stringify(lines))}&_csrf=${encodeURIComponent(csrf)}`
    })
    .then(r => r.json())
    .then(data => {
      msgEl.style.display = 'block';
      msgEl.className = 'schnell-msg ' + (data.ok ? 'schnell-msg--ok' : 'schnell-msg--err');
      let html = data.message;
      if (data.errors && data.errors.length) html += '<ul>' + data.errors.map(e => `<li>${e}</li>`).join('') + '</ul>';
      msgEl.innerHTML = html;
      if (data.ok) {
        document.querySelectorAll('.cart-badge').forEach(b => { b.textContent = data.cartCount; b.style.display = 'flex'; });
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'In den Warenkorb';
    });
  });
})();
</script>

<script>
// ─── Schnellansicht ────────────────────────────────────────────────────────
(function() {
  const overlay  = document.getElementById('quickviewOverlay');
  const closeBtn = document.getElementById('qvClose');
  const imgWrap  = document.getElementById('qvImageWrap');
  const infoCol  = document.getElementById('qvInfoCol');
  const csrf     = '<%= csrfToken %>';

  function fmt(n) {
    return parseFloat(n).toLocaleString('de-AT', { minimumFractionDigits: 3, maximumFractionDigits: 3 }) + ' €';
  }

  function openModal(slug) {
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    imgWrap.innerHTML = '<div class="qv-loading">⟳</div>';
    infoCol.innerHTML = '<div class="qv-loading-full">Wird geladen…</div>';

    fetch('/shop/api/schnellansicht/' + encodeURIComponent(slug))
      .then(r => r.json())
      .then(data => {
        if (!data.ok) { infoCol.innerHTML = '<p style="color:#EF4444">Produkt nicht gefunden.</p>'; return; }
        const p = data.product;
        const imgSrc = p.image || '';
        imgWrap.innerHTML = imgSrc
          ? `<img src="${imgSrc}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;display:block">`
          : `<div class="qv-placeholder">📦</div>`;

        const stockHtml = p.stock > 0
          ? `<div class="qv-stock stock-in">✓ ${p.stock} Stück auf Lager</div>`
          : `<div class="qv-stock stock-out">⚠ Nicht auf Lager</div>`;

        let tiersHtml = '<div class="qv-tiers">';
        p.tiers.forEach((t, i) => {
          const high = i > 0 ? ' qv-tier--green' : '';
          const label = t.max_qty ? `${t.min_qty}–${t.max_qty} Stk` : `Ab ${t.min_qty} Stk`;
          tiersHtml += `<div class="qv-tier${high}"><span class="qv-tier-qty">${label}</span><span class="qv-tier-price">${fmt(t.price)}</span></div>`;
        });
        tiersHtml += '</div>';

        infoCol.innerHTML = `
          <div class="qv-cat">${p.cat_name || ''}</div>
          <h2 class="qv-name">${p.name}</h2>
          ${p.sku ? `<div class="qv-sku">Art.-Nr.: ${p.sku}</div>` : ''}
          <div class="qv-tiers-label">Staffelpreise</div>
          ${tiersHtml}
          ${stockHtml}
          <div class="qv-order-row">
            <input type="number" id="qvQty" class="qty-input" value="1" min="1" style="width:80px">
            ${p.stock > 0
              ? `<button class="btn-add-cart" id="qvAddCart" data-product-id="${p.id}" data-csrf="${csrf}">In den Warenkorb</button>`
              : `<button class="btn-add-cart btn-disabled" disabled>Ausverkauft</button>`}
          </div>
          <a href="/shop/produkt/${p.slug}" class="qv-detail-link">Vollständige Produktdetails →</a>
        `;

        const addBtn = document.getElementById('qvAddCart');
        if (addBtn) {
          addBtn.addEventListener('click', () => {
            const qty = parseInt(document.getElementById('qvQty').value) || 1;
            addBtn.disabled = true;
            addBtn.textContent = '…';
            fetch('/warenkorb/hinzufuegen', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: `product_id=${p.id}&qty=${qty}&_csrf=${encodeURIComponent(csrf)}`
            })
            .then(r => r.json())
            .then(d => {
              if (d.ok) {
                document.querySelectorAll('.cart-badge').forEach(b => { b.textContent = d.cartCount; b.style.display = 'flex'; });
                const msg = document.getElementById('cartToastMsg');
                const toast = document.getElementById('cartToast');
                if (msg && toast) { msg.textContent = d.message || 'Hinzugefügt!'; toast.style.display = 'flex'; setTimeout(() => toast.style.display = 'none', 3000); }
              }
              addBtn.disabled = false;
              addBtn.textContent = 'In den Warenkorb';
            });
          });
        }
      });
  }

  function closeModal() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.addEventListener('click', e => {
    const btn = e.target.closest('.quickview-btn');
    if (btn) { e.preventDefault(); openModal(btn.dataset.slug); }
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
})();
</script>

<%- include('partials/footer') %>
